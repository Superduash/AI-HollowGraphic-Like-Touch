# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ─── Distribution / packaging ─────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST
wheels/
share/python-wheels/

# ─── Testing / coverage ───────────────────────────────────────────────────────
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/

# ─── Type checkers ────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ─── Editors & IDEs ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.cursorrules
.cursorignore
.cursorindexingignore

# ─── OS-generated ─────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
$RECYCLE.BIN/

# ─── Project-specific generated files ─────────────────────────────────────────
# Snapshot export — regenerate with: python export.py
project_compact_export.txt

# pip hash cache written by run.bat
.venv/.requirements.sha256

# Logs
*.log

# ─── Installer / build artifacts ──────────────────────────────────────────────
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Release binaries (must be uploaded to GitHub Releases, not tracked directly)
release/*.exe
